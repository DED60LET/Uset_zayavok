@model Dictionary<string, int>

@{
    ViewData["Title"] = "Статистика системы";
    string feedbackUrl = "https://forms.gle/BytServiceFeedbackExample";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center">Статистика и статусы заявок</h2>

    <div class="alert alert-info shadow-sm text-center">
        <h4>Всего зарегистрировано заявок: <strong>@ViewBag.TotalRequests</strong></h4>
    </div>

    <div class="row mt-4">
        @foreach (var status in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center">
                        <h5 class="card-title text-muted">@status.Key</h5>
                        <p class="display-4 font-weight-bold text-primary">@status.Value</p>

                        @{
                            string progressColor = status.Key == "Готова к выдаче" ? "bg-success" :
                            status.Key == "В процессе ремонта" ? "bg-warning" : "bg-secondary";
                        }
                        <div class="progress" style="height: 10px;">
                            <div class="progress-bar @progressColor" role="progressbar"
                                 style="width: @(ViewBag.TotalRequests > 0 ? (status.Value * 100 / ViewBag.TotalRequests) : 0)%">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row text-center mb-4">
        <div class="col-md-6 mb-3">
            <div class="card bg-success text-white shadow-sm">
                <div class="card-body">
                    <h3>@ViewBag.CompletedCount</h3>
                    <p class="mb-0">Выполнено заявок</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card bg-warning text-dark shadow-sm">
                <div class="card-body">
                    <h3>@ViewBag.AverageTime дней</h3>
                    <p class="mb-0">Среднее время ремонта</p>
                </div>
            </div>
        </div>
    </div>

    <hr class="my-5" />

    <div class="row justify-content-center">
        <div class="col-md-6 text-center shadow-sm p-4 bg-light rounded border">
            <h4 class="mb-3"><i class="bi bi-qr-code"></i> Оценка качества</h4>
            <p class="text-muted">Отсканируйте код мобильным устройством, чтобы оставить отзыв о нашей работе</p>

            <div class="d-inline-block p-3 bg-white rounded shadow-sm">
                <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=@feedbackUrl"
                     alt="QR-код для отзыва"
                     style="width: 180px; height: 180px;" />
            </div>

            <div class="mt-3">
                <a href="@feedbackUrl" target="_blank" class="btn btn-link text-primary">
                    Или перейдите по прямой ссылке
                </a>
            </div>
        </div>
    </div>

    <div class="text-center mt-5 mb-5">
        <a asp-action="Index" class="btn btn-outline-dark px-5">Перейти к полному списку</a>
    </div>
</div>