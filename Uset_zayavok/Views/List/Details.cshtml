@model Uset_zayavok.Models.Request

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Заявка №@Model.Requestid</h3>
            <span class="badge @(Model.Requeststatus == "Готова к выдаче" ? "bg-success" : "bg-warning") p-2">
                @Model.Requeststatus
            </span>
        </div>
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6 border-end">
                    <h5 class="text-muted border-bottom pb-2">Информация об оборудовании</h5>
                    <p><strong>Тип техники:</strong> @Model.Hometechtype</p>
                    <p><strong>Модель:</strong> @Model.Hometechmodel</p>
                    <p>
                        <strong>Описание проблемы:</strong> <br />
                        @* Исправлено под твою модель (через 'y') *@
                        <span class="text-secondary">@Model.Problemdescryption</span>
                    </p>
                </div>

                <div class="col-md-6 ps-4">
                    <h5 class="text-muted border-bottom pb-2">Детали ремонта</h5>
                    <p><strong>Дата создания:</strong> @Model.Startdate?.ToString("dd.MM.yyyy")</p>
                    <p><strong>Дата завершения:</strong> @(Model.Completiondate?.ToString("dd.MM.yyyy") ?? "—")</p>
                    <p><strong>Приоритет:</strong> @(Model.Priority ?? "Не указан")</p>
                    <p><strong>Мастер:</strong> @(Model.Master?.Fio ?? "Не назначен")</p>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.MasterReport))
            {
                <div class="mt-4 p-3 bg-light rounded border">
                    <h5 class="text-success"><i class="bi bi-check-circle"></i> Отчет о проделанной работе:</h5>
                    <p class="mb-0">@Model.MasterReport</p>
                    @if (!string.IsNullOrEmpty(Model.TimeSpent))
                    {
                        <hr />
                        <small class="text-muted">Затрачено времени: @Model.TimeSpent</small>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Repairparts))
            {
                <div class="mt-2 text-muted small">
                    <strong>Запчасти:</strong> @Model.Repairparts
                </div>
            }

            <hr class="my-4" />

            <div class="mt-4">
                <h5>История обсуждения</h5>
                @if (Model.Comments != null && Model.Comments.Any())
                {
                    <div class="list-group">
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="list-group-item list-group-item-action">
                                <h6 class="mb-1 fw-bold">@(comment.Master?.Fio ?? "Система")</h6>
                                <p class="mb-1">@comment.Message</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted small">История комментариев пуста.</p>
                }
            </div>
        </div>
        <div class="card-footer bg-white text-center py-3">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">Назад к списку</a>
            @if (User.IsInRole("Менеджер") || User.IsInRole("Мастер"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Requestid" class="btn btn-primary px-4">Редактировать</a>
            }
        </div>
    </div>
</div>