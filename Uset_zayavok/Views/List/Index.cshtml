@model IEnumerable<Uset_zayavok.Models.Request>

@{
    ViewBag.Title = "Список заявок";
}

<div class="container">
    <h2>Учет заявок на ремонт техники</h2>

    <form method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Поиск по номеру или модели..." />
            <button type="submit" class="btn btn-primary">Найти</button>
        </div>
    </form>
    <div class="card mb-4 shadow-sm border-0 bg-light">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="small fw-bold">Поиск (№ или модель)</label>
                    <input type="text" name="search" class="form-control" value="@Context.Request.Query["search"]" placeholder="Найти...">
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold">Статус</label>
                    <select name="statusFilter" class="form-select">
                        <option value="">Все статусы</option>
                        <option value="Новая заявка">Новые</option>
                        <option value="В процессе ремонта">В работе</option>
                        <option value="Ожидание запчастей">Ожидание запчастей</option>
                        <option value="Готова к выдаче">Готовы</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="small fw-bold">Тип техники</label>
                    <select name="typeFilter" class="form-select">
                        <option value="">Все типы</option>
                        @foreach (var type in ViewBag.Types)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Применить фильтры</button>
                </div>
            </form>
        </div>
    </div>
    @if (User.IsInRole("Менеджер"))
    {
        <div class="alert alert-warning shadow-sm border-warning">
            <strong>Режим менеджера по качеству:</strong> Вы можете изменить описание проблемы для фиксации продления срока или переназначить мастера.
        </div>
    }
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>№</th>
                <th>Дата</th>
                <th>Техника</th>
                <th>Модель</th>
                <th>Статус</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Requestid</td>
                    <td>@(item.Startdate?.ToShortDateString())</td>
                    <td>@item.Hometechtype</td>
                    <td>@item.Hometechmodel</td>
                    <td>
                        <span class="badge @(item.Requeststatus == "Готова к выдаче" ? "bg-success" : "bg-warning")">
                            @item.Requeststatus
                        </span>
                    </td>
                    <td>
                        <div class="btn-group">
                            <a asp-action="Details" asp-route-id="@item.Requestid" class="btn btn-sm btn-info">Просмотр</a>

                            @if (User.IsInRole("Менеджер") || User.IsInRole("Администратор") || User.IsInRole("Мастер"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Requestid" class="btn btn-sm btn-primary">Изменить</a>
                            }

                            @if (User.IsInRole("Менеджер") || User.IsInRole("Администратор"))
                            {
                                <form asp-action="Delete" asp-route-id="@item.Requestid" method="post"
                                      onsubmit="return confirm('Вы уверены, что хотите удалить эту заявку?');" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
              
            }
        </tbody>
    </table>
</div>