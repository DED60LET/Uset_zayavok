@model IEnumerable<Uset_zayavok.Models.User>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Список сотрудников</h2>
    </div>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ФИО</th>
                <th>Должность</th>
                <th>Номер телефона</th>
                <th>Логин</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Fio</td>
                    <td>
                        <span class="badge @(user.Type == "Администратор" ? "bg-danger" : "bg-info text-dark")">
                            @user.Type
                        </span>
                    </td>
                    <td>@user.Phone</td>
                    <td>@user.Login</td>
                </tr>
            }
        </tbody>
    </table>
</div>